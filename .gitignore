# local configuration (not committed)
home/.config/shell/localrc

# OS-specific files
.DS_Store
Thumbs.db
desktop.ini

# backup files
*~
*.bak
*.bak.*
*.tmp
*.old
*.orig
*.swp
*.swo

# editor-specific
.vim/plugins
.vim/undodir
.vscode/
.idea/
*.code-workspace
*.sublime-workspace
*.sublime-project

# shell history & credentials
.history
.bash_history
.zsh_history
.zsh_sessions/
.lesshst
.mysql_history
.psql_history
.python_history

# SSH and GPG (sensitive)
.ssh/
.gnupg/

# local environment or secrets
.env
.envrc
*.secret
*.key
*.pem

# cache directories
.cache/
.local/
.npm/
.node_repl_history
.m2/
.cargo/
.rustup/

# version manager state files
.python-version
.pyenv/
.rbenv-version
.ruby-version
mise.lock
.mise.toml

# macOS and Linux trash
.Trash-*
.Trash/

# logs
*.log
