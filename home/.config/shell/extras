# ~/.config/shell/extras
#
# integrations with external tools and programs.

shell="bash"
[ -n "$ZSH_VERSION" ] && shell="zsh"

# mise (universal language manager)
if command -v "mise" /dev/null 2>&1; then
  eval "$(mise activate $shell)"
fi

# fuzzy finder
if command -v "fzf" >/dev/null 2>&1; then
  export FZF_DEFAULT_OPTS="--style minimal --color 16 --layout=reverse --height 40%"
  export FZF_CTRL_R_OPTS="--style minimal --color 16 --info inline --no-sort --no-preview"

  if command -v "bat" >/dev/null 2>&1; then
    export FZF_DEFAULT_OPTS="--style minimal --color 16 --layout=reverse --height 40% --preview='bat --color=always {}'"
  fi

	eval "$(fzf --$shell)"
fi

# starship prompt
if command -v "starship" /dev/null 2>&1; then
  eval "$(starship init $shell)"
fi

# zoxide (smart `cd` replacement) for faster navigation
if command -v "zoxide" /dev/null 2>&1; then
  eval "$(zoxide init --cmd cd $shell)"
fi

# bat
if command -v "bat" >/dev/null 2>&1; then
	alias cat='bat'

  export MANPAGER="bat -plman"
fi
